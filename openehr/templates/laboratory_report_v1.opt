                    <items id="description">Test has been cancelled</items>
                </term_definitions>
                <term_definitions code="at0012">
                    <items id="text">Test Result</items>
                    <items id="description">Individual test result component</items>
                </term_definitions>
                <term_definitions code="at0013">
                    <items id="text">Result Name</items>
                    <items id="description">Name of the individual result</items>
                </term_definitions>
                <term_definitions code="at0014">
                    <items id="text">Result Value</items>
                    <items id="description">The value of the result</items>
                </term_definitions>
                <term_definitions code="at0015">
                    <items id="text">Reference Range</items>
                    <items id="description">The reference range for this result</items>
                </term_definitions>
                <term_definitions code="at0016">
                    <items id="text">Interpretation</items>
                    <items id="description">Clinical interpretation of the result</items>
                </term_definitions>
                <term_definitions code="at0017">
                    <items id="text">Normal</items>
                    <items id="description">Result is within normal range</items>
                </term_definitions>
                <term_definitions code="at0018">
                    <items id="text">High</items>
                    <items id="description">Result is above normal range</items>
                </term_definitions>
                <term_definitions code="at0019">
                    <items id="text">Low</items>
                    <items id="description">Result is below normal range</items>
                </term_definitions>
                <term_definitions code="at0020">
                    <items id="text">Abnormal</items>
                    <items id="description">Result is abnormal</items>
                </term_definitions>
                <term_definitions code="at0021">
                    <items id="text">Comment</items>
                    <items id="description">Additional comment about the result</items>
                </term_definitions>
                <term_definitions code="at0022">
                    <items id="text">Overall Interpretation</items>
                    <items id="description">Overall clinical interpretation of all test results</items>
                </term_definitions>
                <term_definitions code="at0023">
                    <items id="text">Clinical Information</items>
                    <items id="description">Clinical information provided with the test request</items>
                </term_definitions>
                <term_definitions code="at0024">
                    <items id="text">Tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0025">
                    <items id="text">Test Method</items>
                    <items id="description">Method used to perform the test</items>
                </term_definitions>
                <term_definitions code="at0026">
                    <items id="text">Laboratory</items>
                    <items id="description">Laboratory where the test was performed</items>
                </term_definitions>
                <term_definitions code="at0027">
                    <items id="text">Specimen Type</items>
                    <items id="description">Type of specimen used for the test</items>
                </term_definitions>
                <term_definitions code="at0028">
                    <items id="text">Specimen</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0029">
                    <items id="text">Analyte Result</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0000">
                    <items id="text">Laboratory Test Result</items>
                    <items id="description">The result of a laboratory test</items>
                </term_definitions>
            </children>
            <cardinality>
