                <term_definitions code="at0000">
                    <items id="text">Vital Signs</items>
                    <items id="description">Measurement of vital signs including blood pressure, heart rate, temperature, respiratory rate, and oxygen saturation</items>
                </term_definitions>
                <term_definitions code="at0001">
                    <items id="text">Event Series</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0002">
                    <items id="text">Any event</items>
                    <items id="description">Default, unspecified point in time or interval event</items>
                </term_definitions>
                <term_definitions code="at0003">
                    <items id="text">Tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0004">
                    <items id="text">Systolic Blood Pressure</items>
                    <items id="description">Peak systemic arterial blood pressure - measured in systolic or contraction phase</items>
                </term_definitions>
                <term_definitions code="at0005">
                    <items id="text">Diastolic Blood Pressure</items>
                    <items id="description">Minimum systemic arterial blood pressure - measured in diastolic or relaxation phase</items>
                </term_definitions>
                <term_definitions code="at0006">
                    <items id="text">Heart Rate</items>
                    <items id="description">The rate of the heart in beats per minute</items>
                </term_definitions>
                <term_definitions code="at0007">
                    <items id="text">Body Temperature</items>
                    <items id="description">The measured body temperature</items>
                </term_definitions>
                <term_definitions code="at0008">
                    <items id="text">Respiratory Rate</items>
                    <items id="description">The rate of respiration in breaths per minute</items>
                </term_definitions>
                <term_definitions code="at0009">
                    <items id="text">Oxygen Saturation (SpO2)</items>
                    <items id="description">The oxygen saturation measured by pulse oximetry</items>
                </term_definitions>
                <term_definitions code="at0010">
                    <items id="text">Comments</items>
                    <items id="description">Additional comments about the vital signs measurement</items>
                </term_definitions>
                <term_definitions code="at0011">
                    <items id="text">Tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0012">
                    <items id="text">Position</items>
                    <items id="description">The position of the patient during measurement</items>
                </term_definitions>
                <term_definitions code="at0013">
                    <items id="text">Lying</items>
                    <items id="description">Patient is lying down</items>
                </term_definitions>
                <term_definitions code="at0014">
                    <items id="text">Sitting</items>
                    <items id="description">Patient is sitting</items>
                </term_definitions>
                <term_definitions code="at0015">
                    <items id="text">Standing</items>
                    <items id="description">Patient is standing</items>
                </term_definitions>
                <term_definitions code="at0016">
                    <items id="text">Tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0017">
                    <items id="text">Device</items>
                    <items id="description">Details of the device used to measure vital signs</items>
                </term_definitions>
                <term_definitions code="mm[Hg]">
                    <items id="text">mmHg</items>
                    <items id="description">millimeters of mercury</items>
                </term_definitions>
            </children>
